from fastapi import FastAPI,HTTPException
from pydantic import BaseModel
import sqlite3
from typing import Optional

app = FastAPI(title="My API",version="2.0.0")

class Task(BaseModel):
    title:str
    done:bool = False

class TaskResponse(Task):
    id:int

DATABASE = "tasks.db"

def get_db():
    conn = sqlite3.connect(DATABASE)
    conn.row_factory = sqlite3.Row
    return conn

def init_db():
    with get_db() as conn:
        conn.execute("""CREATE TABLE IF NOT EXISTS tasks (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            title TEXT NOT NULL,
            done BOOLEAN NOT NULL DEFAULT 0
        )""")
        conn.commit()

init_db()

@app.get("/tasks")
def get_tasks():
    conn = get_db()
    rows = conn.execute("SELECT * FROM tasks ORDER BY id").fetchall()
    conn.close()
    tasks = [dict(row) for row in rows]
    return {"code" : 200, "data" : tasks}

@app.post("/tasks", status_code=201)
async def create_task(task: Task):
    conn = get_db()
    cur = conn.execute(
        "INSERT INTO tasks (title, done) VALUES (?, ?)",
        (task.title, task.done)
    )
    conn.commit()
    new_id = cur.lastrowid
    conn.close()

    return {
        "code": 201,
        "data": {"id": new_id, "title": task.title, "done": task.done}
    }

@app.get("/tasks/{task_id}")
async def get_task(task_id: int):
    conn = get_db()
    row = conn.execute(
        "SELECT * FROM tasks WHERE id = ?", (task_id,)
    ).fetchone()
    conn.close()

    if not row:
        raise HTTPException(status_code=404, detail="任务未找到")

    return {"code": 200, "data": dict(row)}

@app.put("/tasks/{task_id}")
async def update_task(task_id: int, task: Task):
    conn = get_db()
    row = conn.execute(
        "SELECT * FROM tasks WHERE id = ?", (task_id,)
    ).fetchone()

    if not row:
        conn.close()
        raise HTTPException(status_code=404, detail="任务未找到")

    conn.execute(
        "UPDATE tasks SET title = ?, done = ? WHERE id = ?",
        (task.title, task.done, task_id)
    )
    conn.commit()
    conn.close()

    return {"code": 200, "data": {"id": task_id, "title": task.title, "done": task.done}}

@app.delete("/tasks/{task_id}")
async def delete_task(task_id: int):
    conn = get_db()
    row = conn.execute(
        "SELECT * FROM tasks WHERE id = ?", (task_id,)
    ).fetchone()

    if not row:
        conn.close()
        raise HTTPException(status_code=404, detail="任务未找到")

    conn.execute("DELETE FROM tasks WHERE id = ?", (task_id,))
    conn.commit()
    conn.close()

    return {"code": 200, "data": {"msg": "已删除"}}

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="127.0.0.1", port=8000)
